{
  "name": "agente-siat",
  "version": "1.0.0",
  "description": "Servidor MCP para Facturación Electrónica del SIAT (Bolivia)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "eval": "tsx tests/evals/eval.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/server.js"
