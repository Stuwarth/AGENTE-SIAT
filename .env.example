# ============================================
# CREDENCIALES DEL SIAT (Impuestos Nacionales)
# ============================================
# IMPORTANTE: Nunca subas el archivo .env real a GitHub.
# Copia este archivo como .env y llena los valores.

# Ambiente: "piloto" o "produccion"
SIAT_AMBIENTE=piloto

# NIT del contribuyente (quien emite las facturas)
SIAT_NIT=

# Token Delegado (se genera en el portal SIAT)
SIAT_TOKEN_DELEGADO=

# Código de Sistema (registrado en el portal SIAT)
SIAT_CODIGO_SISTEMA=

# Código de Sucursal (0 = Casa Matriz)
SIAT_CODIGO_SUCURSAL=0

# Código de Punto de Venta (0 = No aplica)
SIAT_CODIGO_PUNTO_VENTA=0

# Ruta al certificado digital (.p12 o .pfx) para firma XMLDSig
SIAT_CERTIFICADO_RUTA=
SIAT_CERTIFICADO_PASSWORD=
